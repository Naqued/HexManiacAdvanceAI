<UserControl x:Class="HavenSoft.HexManiac.WPF.Controls.AiPanel"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:HavenSoft.HexManiac.WPF.Controls"
      xmlns:hmar="clr-namespace:HavenSoft.HexManiac.WPF.Resources"
      Background="{DynamicResource Background}">
   <Grid>
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="*"/>
         <RowDefinition Height="Auto"/>
         <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Header -->
      <DockPanel Grid.Row="0" Margin="5,3">
         <Button DockPanel.Dock="Right" Command="{hmar:MethodCommand Close}" Width="20" Height="20" ToolTip="Close">
            <Path Data="{hmar:Icon Exit}" Fill="{DynamicResource Secondary}" Stretch="Uniform"/>
         </Button>
         <Button DockPanel.Dock="Right" Command="{Binding ClearCommand}" Width="50" Height="20" Margin="0,0,4,0"
                 Content="Clear" FontSize="10" ToolTip="Clear conversation"/>
         <Button DockPanel.Dock="Right" Command="{Binding ToggleSettingsCommand}" Width="50" Height="20" Margin="0,0,4,0"
                 Content="Settings" FontSize="10" ToolTip="Toggle settings"/>
         <TextBlock Text="AI Assistant" FontWeight="Bold" Foreground="{DynamicResource Primary}" VerticalAlignment="Center"/>
      </DockPanel>

      <!-- Settings Section -->
      <Border Grid.Row="1" Margin="5,0" Padding="6,4" CornerRadius="4"
              Background="{DynamicResource Backlight}" BorderBrush="{DynamicResource Secondary}" BorderThickness="1">
         <Border.Style>
            <Style TargetType="Border">
               <Setter Property="Visibility" Value="Collapsed"/>
               <Style.Triggers>
                  <DataTrigger Binding="{Binding ShowSettings}" Value="True">
                     <Setter Property="Visibility" Value="Visible"/>
                  </DataTrigger>
               </Style.Triggers>
            </Style>
         </Border.Style>
         <StackPanel>
            <DockPanel Margin="0,2">
               <TextBlock Text="Provider:" Width="65" VerticalAlignment="Center" Foreground="{DynamicResource Secondary}" FontSize="11"/>
               <ComboBox SelectedValue="{Binding Settings.ProviderName}" IsEditable="False"
                         FontFamily="Consolas" FontSize="11" MaxHeight="24"
                         Background="{DynamicResource Background}" Foreground="{DynamicResource Primary}"
                         BorderBrush="{DynamicResource Secondary}" BorderThickness="1">
                  <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Anthropic</System:String>
                  <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Mistral</System:String>
                  <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">OpenAI</System:String>
                  <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">Ollama</System:String>
               </ComboBox>
            </DockPanel>
            <DockPanel Margin="0,2">
               <TextBlock Text="API Key:" Width="65" VerticalAlignment="Center" Foreground="{DynamicResource Secondary}" FontSize="11"/>
               <PasswordBox Name="ApiKeyBox" PasswordChanged="ApiKeyBox_PasswordChanged"
                            FontFamily="Consolas" FontSize="11" MaxHeight="24"
                            Background="{DynamicResource Background}" Foreground="{DynamicResource Primary}"
                            BorderBrush="{DynamicResource Secondary}" BorderThickness="1"/>
            </DockPanel>
            <DockPanel Margin="0,2">
               <TextBlock Text="Model:" Width="65" VerticalAlignment="Center" Foreground="{DynamicResource Secondary}" FontSize="11"/>
               <TextBox Text="{Binding Settings.ModelName, UpdateSourceTrigger=PropertyChanged}"
                        FontFamily="Consolas" FontSize="11" MaxHeight="24"
                        Background="{DynamicResource Background}" Foreground="{DynamicResource Primary}"
                        BorderBrush="{DynamicResource Secondary}" BorderThickness="1"/>
            </DockPanel>
            <DockPanel Margin="0,2">
               <TextBlock Text="Base URL:" Width="65" VerticalAlignment="Center" Foreground="{DynamicResource Secondary}" FontSize="11"/>
               <TextBox Text="{Binding Settings.BaseUrl, UpdateSourceTrigger=PropertyChanged}"
                        FontFamily="Consolas" FontSize="11" MaxHeight="24"
                        Background="{DynamicResource Background}" Foreground="{DynamicResource Primary}"
                        BorderBrush="{DynamicResource Secondary}" BorderThickness="1"/>
            </DockPanel>
         </StackPanel>
      </Border>

      <!-- Messages -->
      <ScrollViewer Grid.Row="2" Name="MessageScroller" VerticalScrollBarVisibility="Auto" Margin="5,0">
         <ItemsControl Name="MessageList" ItemsSource="{Binding Messages}">
            <ItemsControl.ItemTemplate>
               <DataTemplate>
                  <Border Margin="0,2" Padding="6,4" CornerRadius="4" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource Backlight}">
                     <StackPanel>
                        <TextBlock FontSize="10" Foreground="{DynamicResource Secondary}" Margin="0,0,0,2">
                           <TextBlock.Style>
                              <Style TargetType="TextBlock">
                                 <Setter Property="Text" Value="Assistant"/>
                                 <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                       <Setter Property="Text" Value="You"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsTool}" Value="True">
                                       <Setter Property="Text" Value="Tool"/>
                                    </DataTrigger>
                                 </Style.Triggers>
                              </Style>
                           </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Foreground="{DynamicResource Primary}"
                                   FontFamily="Consolas" FontSize="12"/>
                     </StackPanel>
                  </Border>
               </DataTemplate>
            </ItemsControl.ItemTemplate>
         </ItemsControl>
      </ScrollViewer>

      <!-- Input -->
      <Grid Grid.Row="3" Margin="5,3">
         <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
         </Grid.ColumnDefinitions>
         <TextBox Name="InputBox" Grid.Column="0" Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                  FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" AcceptsReturn="True"
                  MaxHeight="120" VerticalScrollBarVisibility="Auto"
                  Background="{DynamicResource Background}" Foreground="{DynamicResource Primary}"
                  BorderBrush="{DynamicResource Secondary}" BorderThickness="1"
                  PreviewKeyDown="InputBox_PreviewKeyDown"/>
         <StackPanel Grid.Column="1" Margin="4,0,0,0" VerticalAlignment="Bottom">
            <Button Command="{Binding SendCommand}" Width="50" Height="24" Content="Send" Margin="0,0,0,2"/>
            <Button Command="{Binding CancelCommand}" Width="50" Height="24" Content="Stop"/>
         </StackPanel>
      </Grid>

      <!-- Status -->
      <TextBlock Grid.Row="4" Text="{Binding StatusText}" Foreground="{DynamicResource Secondary}"
                 FontSize="10" Margin="5,0,5,3"/>
   </Grid>
</UserControl>
